    {
        "id": "65603ecd16ae86df",
        "type": "function",
        "z": "6849c10d72ac59a7",
        "name": "Gerar Temperatura",
        "func": "let temp = 25 + Math.sin(Date.now()/60000)*5 + (Math.random()-0.5)*2;\nmsg.topic = 'temperature';\nmsg.payload = `sensor_value{sensor=\"temperature_sensor\",unit=\"celsius\"} ${temp.toFixed(2)}`;\nreturn msg;",
        "outputs": 1,
        "x": 350,
        "y": 60,
        "wires": [
            [
                "83de91667e988433"
            ]
        ]
    },
