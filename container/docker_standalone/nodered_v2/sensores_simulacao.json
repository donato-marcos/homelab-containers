        "name": "Gerar Nível",
        "func": "let level = Math.max(0,Math.min(100,60 + Math.sin(Date.now()/120000)*15 + Math.sin(Date.now()/45000)*8 + (Math.random()-0.5)*2));\nmsg.topic='level';\nmsg.payload = `sensor_value{sensor=\"level_sensor\",unit=\"percent\"} ${level.toFixed(1)}`;\nreturn msg;",
        "outputs": 1,
        "x": 350,
        "y": 240,
        "wires": [
            [
                "83de91667e988433"
