    {
        "id": "a7f067d102841bfc",
        "type": "function",
        "z": "6849c10d72ac59a7",
        "name": "Gerar Energia",
        "func": "if(!context.energyTotal){context.energyTotal=0; context.lastTime=Date.now();}\nlet elapsedHours=(Date.now()-context.lastTime)/(1000*60*60);\nlet currentPower=Math.max(0,15 + Math.sin(Date.now()/180000)*8 + (Math.random()-0.5)*3);\ncontext.energyTotal+=currentPower*elapsedHours;\ncontext.lastTime=Date.now();\nmsg.topic='energy';\nmsg.payload=`sensor_value{sensor=\"energy_sensor\",unit=\"kWh\"} ${context.energyTotal.toFixed(3)}`;\nreturn msg;",
        "outputs": 1,
        "x": 350,
        "y": 360,
        "wires": [
            [
                "83de91667e988433"
            ]
        ]
    },
