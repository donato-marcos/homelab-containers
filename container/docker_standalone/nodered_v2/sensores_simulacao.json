        "name": "Gerar Vazão",
        "func": "let flow = Math.max(0,50+Math.sin(Date.now()/15000)*20+(Math.random()>0.9?30:0)+(Math.random()-0.5)*5);\nmsg.topic='flow';\nmsg.payload = `sensor_value{sensor=\"flow_sensor\",unit=\"L_min\"} ${flow.toFixed(2)}`;\nreturn msg;",
