# Kea version
VERSION="3.1.9"

# Interface for DHCP service
ETH="enp1s0"

# ============================================
# IPv4 Settings for compose
# ============================================
IP4="172.16.11.253"
IP4_V6="fd00:172:16:11::253" # V6 address for Kea 4 Server - required to set static in V6 subnet to avoid conflict with dhcp pool.
SUBNET4="172.16.11.0/24"
#GATEWAY4="172.16.11.254"

# ============================================
# IPv6 Settings for compose
# ============================================
IP6="fd00:172:16:11::252"
IP6_V4="172.16.11.252" # V4 address for Kea 6 Server - required to set static in V4 subnet to avoid conflict with dhcp pool.
SUBNET6="fd00:172:16:11::/64"
#GATEWAY6="fd00:172:16:11::254"


# ============================================
# Settings for pools (IPv4 and IPv6) - used in subnets*.json files
# ============================================
SUBNET4_POOL_ID="1"
SUBNET4_POOL="10.20.11.0/24"
POOL4="10.20.11.21-10.20.11.248"
ROUTER4="10.20.11.254"
DNS4="172.16.11.11, 1.1.1.1"
DOMAIN_SEARCH4="teste.local"

SUBNET6_POOL_ID="1"
SUBNET6_POOL="fd00:10:20:11::/64"
POOL6="fd00:10:20:11::100-fd00:10:20:11::1ff"
ROUTER6="fd00:10:20:11::254"
DNS6="fd00:172:16:11::11, 2606:4700:4700::1111"
DOMAIN_SEARCH6="teste.local"